# ============================================================
# VortexAI Platform — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ─── App ─────────────────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=change-me-to-a-long-random-string

# ─── Database (Railway Postgres) ─────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/railway

# ─── Redis (Railway Redis) ───────────────────────────────────
REDIS_URL=redis://default:PASSWORD@HOST:6379

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://your-frontend.railway.app,https://yourdomain.com

# ─── BatchData API (Real Estate Leads) ───────────────────────
BATCHDATA_TOKEN=your-batchdata-token

# ─── HouseCanary API (ARV + Comps) ───────────────────────────
HOUSECANARY_API_KEY=your-housecanary-key
HOUSECANARY_API_SECRET=your-housecanary-secret

# ─── DocuSign ────────────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=your-integration-key
DOCUSIGN_SECRET_KEY=your-secret-key
DOCUSIGN_ACCOUNT_ID=your-account-id
DOCUSIGN_USER_ID=your-user-id
DOCUSIGN_PRIVATE_KEY=your-rsa-private-key-base64
DOCUSIGN_BASE_URL=https://na4.docusign.net/restapi
DOCUSIGN_WEBHOOK_SECRET=your-webhook-hmac-secret

# ─── Twilio (SMS) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+16203501517

# ─── SendGrid (Email) ────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=VortexAI Platform

# ─── Stripe (Dealer Billing) ─────────────────────────────────
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here

# ─── Make.com (Car Lead Automation) ──────────────────────────
MAKE_WEBHOOK_URL=https://hook.us1.make.com/your-webhook-path

# ─── API URLs (inter-service communication) ──────────────────
# Set this in the frontend service to point to the API service
API_BASE_URL=https://api-vortexai-production.up.railway.app
